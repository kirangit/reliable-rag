# Copy this file to `.env` and fill in your keys. `.env` is gitignored.
# ---------------------------------------------------------------------------

# --- Required for live runs (ingest / ask / eval / the UIs) ---
# Claude powers generation, the Grade & Verify gates, and the RAGAS judge.
ANTHROPIC_API_KEY=
# OpenAI powers ONLY the embeddings (Anthropic has no embeddings API).
OPENAI_API_KEY=

# --- Models (sensible defaults; override only if you know why) ---
GENERATION_MODEL=claude-sonnet-4-6
GRADE_MODEL=claude-sonnet-4-6
VERIFY_MODEL=claude-opus-4-8
JUDGE_MODEL=claude-opus-4-8
EMBEDDING_MODEL=text-embedding-3-small

# --- Corpus / index ---
DOCS_DIR=docs
CHROMA_DIR=.chroma
COLLECTION_NAME=cnwave

# --- Retrieval + reliability knobs ---
RETRIEVAL_MODE=hybrid        # hybrid (dense+BM25) | dense
RETRIEVE_K=8                 # over-retrieve a little; the Grade gate filters the noise
CONTEXT_WINDOW=1             # context-enrichment window: feed each kept chunk's ±N same-doc neighbors (0=off)
GRADE_THRESHOLD=0.5          # keep chunks scored >= this by the Grade gate
MIN_KEPT_CHUNKS=2            # below this after grading -> rewrite query, then abstain
MAX_ATTEMPTS=2              # generate/verify retry budget
ENABLE_VERIFY=true
VERIFY_MAX_TOKENS=8192        # Verify restates each claim+reason as structured output -> needs more room than the answer
CONVERSATIONAL=false         # multi-turn: condense follow-ups into a standalone query using chat history

# --- Chunking ---
MAX_CHUNK_CHARS=1200         # markdown sections larger than this get a size-guard split
CHUNK_OVERLAP=100
HEADER_SPLIT_MAX_LEVEL=2      # split markdown on '#'/'##' only; deeper headings (###+) stay in-content

# --- Observability ---
TRACING=none                 # none | phoenix (local) | langsmith (hosted)
LOG_LEVEL=INFO               # DEBUG dumps full chunk text + prompts
RUNS_DIR=runs
FEEDBACK_DIR=feedback

# --- LangSmith (only if TRACING=langsmith) ---
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=reliable-rag
